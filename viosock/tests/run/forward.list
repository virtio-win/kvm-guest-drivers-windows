# forward.list — vsock_test IDs to run in the forward direction
# (Linux = vsock acceptor / --mode=server, Windows = vsock connector / --mode=client).
#
# Row format:
#   <id>  <variant>  <description>
#     id        Numeric --pick ID (matches upstream Linux vsock_test).
#     variant   Which Windows-side port to invoke.  See variant_to_cmd()
#               in _lib.sh for the current mapping.
#                 posix — the compat.h-driven POSIX-source port
#                 wsa   — the native Winsock port (Phase 2, when it exists)
#     description  Free text, mirrors the .name field in test_cases[].
#
# To disable a row without deleting: leading `#` and MUST include a
# "disabled: <reason>" note on the same line.  Contract: every enabled
# (id, variant) row MUST pass — failure is a regression.
#
# Current baseline: vhi-8.1 HEAD 3ec8ad6a.  Only rows known to pass on
# that baseline are enabled here; NULL-in-table rows and driver-side
# fails are commented out with the exact failure fingerprint so the
# next reader can turn a row green with a one-line uncomment.

0    posix  SOCK_STREAM connection reset
1    posix  SOCK_STREAM bind only
2    posix  SOCK_STREAM client close
3    posix  SOCK_STREAM server close
4    posix  SOCK_STREAM multiple connections
5    posix  SOCK_STREAM MSG_PEEK
# 6  posix  SOCK_SEQPACKET msg bounds                       — disabled: run_client/run_server = NULL (needs SEQPACKET + recvmsg(MSG_EOR))
# 7  posix  SOCK_SEQPACKET MSG_TRUNC flag                   — disabled: run_client/run_server = NULL (needs SEQPACKET + recvmsg)
# 8  posix  SOCK_SEQPACKET timeout                          — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
# 9  posix  SOCK_SEQPACKET invalid receive buffer           — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
10   posix  SOCK_STREAM poll() + SO_RCVLOWAT
# 11 posix  SOCK_SEQPACKET big message                      — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
12   posix  SOCK_STREAM test invalid buffer
# 13 posix  SOCK_SEQPACKET test invalid buffer              — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
14   posix  SOCK_STREAM virtio skb merge
# 15 posix  SOCK_SEQPACKET MSG_PEEK                         — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
# 16 posix  SOCK_STREAM SHUT_WR                             — disabled: run_client/run_server = NULL (Linux-only: SIGPIPE regression)
# 17 posix  SOCK_STREAM SHUT_RD                             — disabled: run_client/run_server = NULL (Linux-only: SIGPIPE regression)
# 18 posix  SOCK_STREAM MSG_ZEROCOPY                        — disabled: run_client/run_server = NULL (no Winsock MSG_ERRQUEUE)
# 19 posix  SOCK_SEQPACKET MSG_ZEROCOPY                     — disabled: run_client/run_server = NULL (no MSG_ERRQUEUE + SEQPACKET)
# 20 posix  SOCK_STREAM MSG_ZEROCOPY empty MSG_ERRQUEUE     — disabled: run_client/run_server = NULL (no MSG_ERRQUEUE)
21   posix  SOCK_STREAM double bind connect
# 22 posix  SOCK_STREAM virtio credit update + SO_RCVLOWAT  — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "send failed: No error" on acceptor (credit-update path bug, forward)
# 23 posix  SOCK_STREAM virtio credit update + low rx_bytes — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "send failed: No error" on acceptor (credit-update low-rx-bytes path)
# 24 posix  SOCK_STREAM ioctl(SIOCOUTQ) 0 unsent bytes      — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "Test skipped, SIOCOUTQ not supported" (compat.h does not route Linux SIOCOUTQ 0x5411 to SIO_VSOCK_OUTQ)
# 25 posix  SOCK_SEQPACKET ioctl(SIOCOUTQ) 0 unsent bytes   — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
# 26 posix  SOCK_STREAM leak accept queue                   — disabled: run_client/run_server = NULL (Linux-only: kmemleak regression)
# 27 posix  SOCK_STREAM MSG_ZEROCOPY leak MSG_ERRQUEUE      — disabled: run_client/run_server = NULL (no MSG_ERRQUEUE + kmemleak)
# 28 posix  SOCK_STREAM MSG_ZEROCOPY leak completion skb    — disabled: run_client/run_server = NULL (no MSG_ERRQUEUE + kmemleak)
# 29 posix  SOCK_STREAM transport release use-after-free    — disabled: run_client/run_server = NULL (Linux-only: /proc/kallsyms + multi-transport)
30   posix  SOCK_STREAM retry failed connect()
31   posix  SOCK_STREAM SO_LINGER null-ptr-deref
# 32 posix  SOCK_STREAM SO_LINGER close() on unread         — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "Test skipped, SIOCOUTQ not supported" (vsock_wait_sent → SIOCOUTQ compat.h gap)
# 33 posix  SOCK_STREAM transport change null-ptr-deref, lockdep warn — disabled: run_client/run_server = NULL (Linux-only: pthread + kill(SIGUSR1))
# 34 posix  SOCK_STREAM ioctl(SIOCINQ) functionality        — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "Test skipped, SIOCINQ not supported" (compat.h does not route Linux SIOCINQ 0x541B to SIO_VSOCK_INQ)
# 35 posix  SOCK_SEQPACKET ioctl(SIOCINQ) functionality     — disabled: run_client/run_server = NULL (SEQPACKET not implemented in driver)
# 36 posix  SOCK_STREAM accept()ed socket custom setsockopt() — disabled: run_client/run_server = NULL (no Winsock SO_ZEROCOPY)
# 37 posix  SOCK_STREAM virtio MSG_ZEROCOPY coalescence corruption — disabled: run_client/run_server = NULL (no MSG_ERRQUEUE)
# 38 posix  SOCK_STREAM TX credit bounds                    — disabled: fails on vhi-8.1 HEAD 3ec8ad6a: "TX credit too large: queued 2097152 bytes (expected <= 65536)" — regression from recv-worker changes (ea7b2ec4/4a6f5682)
